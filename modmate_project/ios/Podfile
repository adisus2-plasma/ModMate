platform :ios, '13.0' # ปูทางไว้ให้ ARKit

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end
  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}."
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)
flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  
  # เพิ่มบรรทัดนี้เพื่อช่วยเรื่อง Library Conflict ของ Firebase/gRPC
  pod 'abseil', :modular_headers => true
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # บังคับเวอร์ชัน iOS ให้ตรงกันทั้งหมด
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'

      # สูตรแก้ -G ที่เราทำสำเร็จมาแล้ว
      ['OTHER_LDFLAGS', 'OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS'].each do |key|
        flags = config.build_settings[key]
        if flags.is_a?(Array)
          flags.delete('-G')
          config.build_settings[key] = flags.empty? ? ['$(inherited)'] : flags
        elsif flags.is_a?(String)
          config.build_settings[key] = flags.gsub(/\s*-G\s*/, ' ').strip
          config.build_settings[key] = '$(inherited)' if config.build_settings[key].empty?
        end
      end
    end
  end
end

post_integrate do |installer|
  # แก้ pbxproj (สูตรลด Warning)
  pbxproj_path = installer.pods_project.path.to_s + '/project.pbxproj'
  if File.exist?(pbxproj_path)
    content = File.read(pbxproj_path)
    File.write(pbxproj_path, content.gsub('-GCC_WARN_INHIBIT_ALL_WARNINGS', '-w'))
  end

  # สูตรแก้ CallSeqFactory ใน gRPC-Core (ที่เราใช้รันวิดีโอผ่าน)
  [
    'gRPC-Core/src/core/lib/promise/detail/basic_seq.h',
    'gRPC-C++/src/core/lib/promise/detail/basic_seq.h'
  ].each do |relative_path|
    file_path = File.join(installer.sandbox.root, relative_path)
    if File.exist?(file_path)
      content = File.read(file_path)
      new_content = content.gsub('Traits::template CallSeqFactory(f_,', 'Traits::template CallSeqFactory<>(f_,')
      File.write(file_path, new_content)
    end
  end
end